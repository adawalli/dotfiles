fish_add_path $HOME/.bun/bin $HOME/.local/bin $HOME/bin
command -q go; and fish_add_path (go env GOPATH)/bin

set -gx EDITOR nvim
set -gx AWS_PAGER ""
set -q fish_greeting; or set -U fish_greeting ""

if status is-interactive
    fish_vi_key_bindings
    {{- if eq .chezmoi.os "darwin" }}
    fish_add_path /Applications/Obsidian.app/Contents/MacOS
    abbr -a icd 'cd ~/Library/Mobile\ Documents/com\~apple\~CloudDocs'
    abbr --add typora open -a typora
    {{- end }}
    {{- if eq .chezmoi.os "linux" }}
    fish_add_path $HOME/.atuin/bin
    {{- end }}
    set -gx VISUAL "code --wait"
end
